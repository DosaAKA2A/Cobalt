<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg2"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/passwords_title"
            android:textColor="@color/text" android:textSize="18sp" android:textStyle="bold" />

        <Button android:id="@+id/pwAdd"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Añadir" android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Cifradas con tu cuenta de Android. Ver una contraseña requiere tu huella o PIN."
        android:textColor="@color/muted" android:textSize="12sp"
        android:padding="16dp" />

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:id="@+id/pwList"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp" />
    </ScrollView>
</LinearLayout>
